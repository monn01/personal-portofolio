// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Profile {
  id             String          @id @default(cuid())
  name           String
  bio            String
  photoUrl       String?
  email          String
  contactLinks   Json? // e.g. [{ "label": "GitHub", "url": "https://github.com/..." }]
  taglines       Json? // string[], mis. ["Mahasiswa Informatika UAD", "Full-Stack Developer"]
  galleryPhotos  Json? // string[] URL foto galeri, ditampilkan di halaman About
  cvUrl          String? // link file CV/resume (PDF)
  heroPhotoUrl   String? // foto khusus hero Home, beda dari photoUrl (dipakai About/navbar)
  heroBio        String? // kalimat pendek khusus hero Home, beda dari bio (dipakai About)
  skills         Skill[]
  experiences    Experience[]
  certifications Certification[]
  achievements   Achievement[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Skill {
  id        String  @id @default(cuid())
  name      String
  iconSlug  String? // slug icon dari library (mis. Simple Icons)
  iconUrl   String? // dipakai kalau upload icon custom
  category  String?
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String
}

model Experience {
  id           String    @id @default(cuid())
  title        String
  organization String
  startDate    DateTime
  endDate      DateTime?
  description  String
  imageUrl     String?
  profile      Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Certification {
  id             String   @id @default(cuid())
  title          String
  issuer         String
  issueDate      DateTime
  credentialUrl  String?
  imageUrl       String
  tier           String   @default("local") // "local" | "international"
  featuredOnHome Boolean  @default(true) // dipilih admin: tampil di preview Home atau tidak
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Achievement {
  id             String   @id @default(cuid())
  title          String
  description    String?
  organizer      String
  year           Int
  tier           String // "local" | "international"
  certificateUrl String?
  imageUrl       String?
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Portfolio {
  id           String   @id @default(cuid())
  title        String
  description  String
  category     String // "web" | "app" | "design"
  thumbnailUrl String?
  year         Int
  role         String
  techStack    Json // string[] tags, mis. ["Next.js", "Tailwind"]
  externalUrl  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Post {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  excerpt       String
  content       String // markdown
  coverImageUrl String?
  published     Boolean   @default(false)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}
