# Dev lokal (SQLite file, pakai driver @prisma/adapter-better-sqlite3)
DATABASE_URL="file:./prisma/dev.db"

# Production (Turso, pakai driver @prisma/adapter-libsql) — contoh:
# DATABASE_URL="libsql://<nama-db>-<org>.turso.io"
# TURSO_AUTH_TOKEN="<token dari `turso db tokens create <nama-db>`>"

# NextAuth (Auth.js) v5 — generate dengan: npx auth secret
AUTH_SECRET="replace-with-random-secret"

# Production only (Vercel dkk): kalau app di-deploy di belakang proxy/host
# yang tidak otomatis dikenali Auth.js, set ini ke "true".
# AUTH_TRUST_HOST="true"

# Cloudinary (Module 10 — image upload). Buat akun gratis di cloudinary.com,
# ambil 3 value ini dari Dashboard > Product Environment Credentials.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# SEO (Module 20) — base URL absolut buat metadataBase, sitemap.xml, robots.txt,
# dan OG image. Kalau kosong: fallback ke VERCEL_URL (auto di Vercel) lalu
# http://localhost:3000. Set ke domain production final setelah deploy, mis:
# NEXT_PUBLIC_SITE_URL="https://nama-domain-kamu.vercel.app"
NEXT_PUBLIC_SITE_URL=""
